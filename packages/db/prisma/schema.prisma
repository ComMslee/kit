// =============================================
// 기본 스키마 — 외주 프로젝트 공통 모델
// 프로젝트마다 도메인 모델을 아래에 추가
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── 공통: 유저 ──────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts   Account[]
  sessions   Session[]
  orders     Order[]
  devices    Device[]
  clientLogs ClientLog[]

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

// ── NextAuth 필수 모델 ──────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── 결제 ────────────────────────────────────
model Order {
  id           String      @id @default(cuid())
  userId       String
  amount       Int
  currency     String      @default("KRW")
  status       OrderStatus @default(PENDING)
  provider     String
  providerTxId String?
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

// ── 디바이스 ─────────────────────────────────
model Device {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  Platform
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

enum Platform {
  IOS
  ANDROID
  WEB
}

// ── 클라이언트 로그 ───────────────────────────
model ClientLog {
  id         String   @id @default(cuid())
  userId     String?
  level      LogLevel
  message    String
  context    Json?
  platform   String?
  appVersion String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("client_logs")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}
