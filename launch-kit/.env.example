# Database
DATABASE_URL="postgresql://user:password@localhost:5432/launch_kit"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
# Generate: openssl rand -base64 32

# Kakao OAuth
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# Naver OAuth
# https://developers.naver.com → Application → 애플리케이션 등록
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
