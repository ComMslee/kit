# ────────────────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────────────────
# 도커 사용 시 (docker-compose.yml 이 자동으로 덮어씀)
DATABASE_URL="postgresql://kituser:kitpassword@postgres:5432/kit_dev"
# 로컬 직접 실행 시 (postgres 대신 localhost 로 변경)
# DATABASE_URL="postgresql://kituser:kitpassword@localhost:5432/kit_dev"

# ────────────────────────────────────────────────────────────
# NextAuth
# ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="dev-secret-change-in-production"
# Generate: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# ────────────────────────────────────────────────────────────
# Kakao OAuth
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API 키
# Redirect URI: http://localhost:3000/api/auth/callback/kakao
# ────────────────────────────────────────────────────────────
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# ────────────────────────────────────────────────────────────
# Naver OAuth
# https://developers.naver.com → Application → 애플리케이션 등록
# Callback URL: http://localhost:3000/api/auth/callback/naver
# ────────────────────────────────────────────────────────────
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# ────────────────────────────────────────────────────────────
# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
# ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
